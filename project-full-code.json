{
  "project_name": "قاموسي الذكي - My Smart Dictionary",
  "version": "4.0.0",
  "description": "تطبيق ذكي لحفظ ومراجعة الكلمات الإنجليزية مع نظام مراجعة متطور ودعم الذكاء الاصطناعي",
  
  "file_structure": {
    "package_json": {
      "name": "nextjs_tailwind_shadcn_ts",
      "version": "0.2.0",
      "scripts": {
        "dev": "next dev -p 3000",
        "build": "next build",
        "start": "NODE_ENV=production bun .next/standalone/server.js",
        "lint": "eslint .",
        "db:push": "prisma db push",
        "db:generate": "prisma generate"
      },
      "dependencies": [
        "@prisma/client",
        "next",
        "react",
        "react-dom",
        "framer-motion",
        "zustand",
        "lucide-react",
        "sonner",
        "tailwindcss",
        "next-themes",
        "bcryptjs",
        "uuid"
      ]
    }
  },

  "database_schema": {
    "models": [
      "User - المستخدم",
      "Category - الفئات",
      "Word - الكلمات",
      "Sentence - الجمل",
      "ReviewSession - جلسات المراجعة",
      "Story - القصص",
      "Note - الملاحظات",
      "CustomList - القوائم المخصصة",
      "LearningPath - مسارات التعلم",
      "Achievement - الإنجازات",
      "AdminVideo - فيديوهات المشرف",
      "AdminLesson - دروس المشرف",
      "AdminCategory - فئات المشرف",
      "KidsQuiz - اختبارات الأشبال",
      "KidsGame - ألعاب الأشبال",
      "KidsFlashcard - بطاقات تعليمية",
      "KidsProgress - تقدم الأشبال"
    ],
    "database": "PostgreSQL (Neon)"
  },

  "main_files": {
    "src_app_page_tsx": {
      "description": "الصفحة الرئيسية - نقطة الدخول للتطبيق",
      "content": "'use client'\n\nimport { useCallback, useEffect, useState, useRef } from 'react'\nimport { AuthPage } from '@/components/auth/AuthPage'\nimport { VocabularyApp } from '@/components/vocabulary-app'\nimport { useAuth } from '@/contexts/AuthContext'\nimport { useVocabStore } from '@/store/vocab-store'\n\nconst APP_VERSION = '4.0.0'\n\nexport default function Page() {\n  const { user, loading: authLoading, logout } = useAuth()\n  const { selectUser, loadWords, loadCategories, loadNotes, loadStats, currentUserId, setUsers } = useVocabStore()\n  const [mounted, setMounted] = useState(false)\n  const [dataLoaded, setDataLoaded] = useState(false)\n\n  useEffect(() => { setMounted(true) }, [])\n\n  useEffect(() => {\n    if (user && !currentUserId) {\n      setUsers([user])\n      selectUser(user.id)\n    }\n  }, [user, currentUserId])\n\n  useEffect(() => {\n    if (currentUserId && user) {\n      Promise.all([loadWords(), loadCategories(), loadNotes()]).then(() => {\n        loadStats()\n        setDataLoaded(true)\n      })\n    }\n  }, [currentUserId, user])\n\n  if (!mounted || authLoading) return <LoadingSpinner />\n  if (!user) return <AuthPage />\n  if (!dataLoaded && currentUserId) return <LoadingSpinner />\n\n  return <VocabularyApp onLogout={logout} />\n}"
    },

    "src_app_layout_tsx": {
      "description": "تخطيط التطبيق الرئيسي",
      "content": "import type { Metadata } from 'next'\nimport './globals.css'\nimport { Toaster } from '@/components/ui/toaster'\nimport { Providers } from '@/components/providers'\n\nexport const metadata: Metadata = {\n  title: 'قاموسي الذكي - Vocabulary Learning App',\n  description: 'تطبيق ذكي لحفظ ومراجعة الكلمات الإنجليزية'\n}\n\nexport default function RootLayout({ children }: { children: React.ReactNode }) {\n  return (\n    <html lang='ar' dir='rtl' suppressHydrationWarning>\n      <body>\n        <Providers>{children}</Providers>\n        <Toaster />\n      </body>\n    </html>\n  )\n}"
    },

    "src_contexts_AuthContext_tsx": {
      "description": "سياق المصادقة - إدارة تسجيل الدخول والخروج",
      "key_features": [
        "تسجيل الدخول بالبريد وكلمة المرور",
        "إنشاء حساب جديد",
        "حفظ الجلسة",
        "تحديث بيانات المستخدم"
      ]
    },

    "src_store_vocab-store_ts": {
      "description": "مخزن Zustand لإدارة حالة التطبيق",
      "key_features": [
        "إدارة المستخدمين",
        "إدارة الكلمات والفئات",
        "نظام المراجعة SM-2",
        "إدارة الملاحظات",
        "تصدير واستيراد البيانات"
      ]
    },

    "src_components_vocabulary-app_tsx": {
      "description": "المكون الرئيسي للتطبيق",
      "sections": [
        "القاموس الذكي - إضافة وعرض الكلمات",
        "المراجعة الذكية - خوارزمية SM-2",
        "الألعاب التعليمية - Quiz, Matching, Speed, Spelling",
        "القصص والملاحظات",
        "المساعد الذكي AI",
        "لوحة المؤسس - للمدير فقط"
      ],
      "founder_email": "manager@gmail.com",
      "admin_password": "founderandmanager"
    },

    "src_components_admin-dashboard_tsx": {
      "description": "لوحة تحكم المؤسس",
      "features": [
        "إدارة فيديوهات الأشبال والكبار",
        "إدارة الفئات",
        "إدارة الدروس",
        "إدارة الإعلانات",
        "إعادة ترتيب الفيديوهات",
        "فلترة حسب الفئة"
      ],
      "default_kids_categories": [
        "الحروف - Alphabet",
        "الأرقام - Numbers",
        "الألوان - Colors",
        "الحيوانات - Animals",
        "الأغاني - Songs",
        "القصص - Stories",
        "الألعاب - Games",
        "الحياة اليومية - Daily Life",
        "أجزاء الجسم - Body Parts",
        "الطعام - Food"
      ]
    }
  },

  "api_routes": {
