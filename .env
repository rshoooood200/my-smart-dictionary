# PostgreSQL Connection for Neon/Vercel Postgres
# 
# FOR VERCEL DEPLOYMENT:
# 1. Go to your Vercel project dashboard
# 2. Click "Storage" tab → "Create Database" → "Postgres (Neon)"
# 3. Link it to your project - it will auto-set DATABASE_URL
# 
# FOR LOCAL DEVELOPMENT:
# Option A: Use the same Neon database (recommended)
# Option B: Use a local PostgreSQL instance
#
# After setting up Neon, replace the URL below:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my-smart-dictionary"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/my-smart-dictionary"

# Session secret for signing cookies - MUST be set in production!
# Generate with: openssl rand -hex 32
SESSION_SECRET="dev-secret-change-in-production-a1b2c3d4e5f6"
