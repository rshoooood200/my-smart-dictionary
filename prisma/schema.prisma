  @@index([category])
  @@index([type])
  @@index([isActive])
  @@index([sourceVideoId])
}

model KidsExerciseAttempt {
  id           String   @id @default(cuid())
  exerciseId   String
  userId       String?
  score        Int      @default(0)
  answers      String   @default("[]") // JSON array of answers
  completedAt  DateTime @default(now())
  exercise     KidsExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
  @@index([completedAt])
}

// نظام شهادات الإنجاز للأشبال
model KidsCertificate {
  id           String   @id @default(cuid())
  title        String
  titleAr      String
  description  String?
  descriptionAr String?
  type         String   @default("completion") // completion, mastery, streak, challenge
  category     String?
  requirement  String   @default("{}") // JSON for requirements
  templateData String   @default("{}") // JSON for certificate design
  xpReward     Int      @default(50)
  icon         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userCertificates KidsUserCertificate[]

  @@index([type])
  @@index([isActive])
}

model KidsUserCertificate {
  id             String   @id @default(cuid())
  certificateId  String
  userId         String?
  childName      String
  issuedAt       DateTime @default(now())
  certificate    KidsCertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([certificateId])
  @@index([userId])
}

// نظام تقدم الأشبال - مرتبط بحساب المستخدم
model KidsProgress {
  id                String   @id @default(cuid())
  userId            String   @unique
  
  // XP and Level
  xp                Int      @default(0)
  level             Int      @default(1)
  
  // Streak
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastActiveDate    DateTime?
  
  // Currency
  coins             Int      @default(0)
  gems              Int      @default(0)
  
  // Stats
  totalVideosWatched   Int   @default(0)
  totalQuizzesCompleted Int  @default(0)
  totalGamesPlayed     Int   @default(0)
  totalLessonsRead     Int   @default(0)
  totalFlashcardsViewed Int  @default(0)
  
  // Quiz attempts
  totalCorrectAnswers  Int   @default(0)
  totalWrongAnswers    Int   @default(0)
  
  // Time tracking
  totalTimeSpent       Int   @default(0) // in seconds
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([level])
}

// Gemini API Configuration for users
model GeminiConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
