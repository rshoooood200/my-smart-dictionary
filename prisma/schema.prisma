  @@index([isActive])
  @@index([sourceVideoId])
}

// نظام التمارين المستخرجة من الفيديوهات
model KidsExercise {
  id           String   @id @default(cuid())
  title        String
  titleAr      String
  instruction  String
  instructionAr String?
  type         String   @default("translation") // translation, listening, speaking, writing, fill_blank
  category     String
  difficulty   String   @default("easy")
  ageGroup     String?
  content      String   @default("{}") // JSON for exercise content
  xpReward     Int      @default(5)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
